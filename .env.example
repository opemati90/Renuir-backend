# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins (mobile apps don't send Origin)
ALLOWED_ORIGINS=https://renuir.com,https://app.renuir.com

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=renuir
DB_USER=postgres
DB_PASS=your_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_64_bytes_minimum

# ─── Firebase (for social login verification) ─────────────────────────────────
GOOGLE_CLOUD_PROJECT=renuir-app
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  (local dev only)

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
BUCKET_NAME=renuirbucket

# ─── SMTP (Email / OTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Shippo (Shipping Labels — Sprint 1) ──────────────────────────────────────
SHIPPO_API_KEY=shippo_test_...

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://renuir.com
